{
  "name": "reactcell",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://scotteratigan.github.io/reactcell",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --react-plugin --vitest-plugin .",
    "lint:fix": "oxlint --react-plugin --vitest-plugin . --fix",
    "format": "oxfmt --write . && uv run ruff format .",
    "format:check": "oxfmt --check . && uv run ruff format --check .",
    "prepare": "husky",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "@vitejs/plugin-react": "^6.0.2",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt --write",
      "oxlint --react-plugin --vitest-plugin --fix"
    ],
    "*.{json,css,html}": "oxfmt --write",
    "*.py": "uv run ruff format"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "npm@11.17.0"
}
